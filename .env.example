# ─────────────────────────────────────────────────────────────
# PescaPlus — variables de entorno (todas OPCIONALES)
# Copia este archivo a .env y rellena lo que necesites.
# La app funciona sin ninguna (catálogo local + experto offline).
# ─────────────────────────────────────────────────────────────

# URL pública del sitio (para metadatos SEO, sitemap y enlaces absolutos)
NEXT_PUBLIC_APP_URL="https://tu-dominio.com"

# Base de datos (Neon PostgreSQL). Si está, el panel persiste en la DB;
# si no, se usa un store en memoria.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Panel de administración (/admin). Sin ella se usa "pescaplus-admin" en dev.
# DEFÍNELA antes de desplegar en producción.
ADMIN_PASSWORD="cambia-esta-contrasena"

# AliExpress Affiliate API (para el importador y productos reales)
ALIEXPRESS_APP_KEY="tu_app_key"
ALIEXPRESS_APP_SECRET="tu_app_secret"
ALIEXPRESS_TRACKING_ID="pescaplus"

# NVIDIA API (asistente IA y generación de fichas)
NVIDIA_API_KEY="nvapi-..."
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
# Cadena de modelos con fallback (si uno falla, prueba el siguiente)
NVIDIA_MODELS="nvidia/nemotron-3-super-120b-a12b,nvidia/llama-3.3-nemotron-super-49b-v1.5,nvidia/nemotron-3-nano-30b-a3b,nvidia/nvidia-nemotron-nano-9b-v2,nvidia/nemotron-mini-4b-instruct"
