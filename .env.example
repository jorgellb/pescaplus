# ─────────────────────────────────────────────────────────────
# PescaPlus — TODAS las variables de entorno
# Copia este archivo a .env (local) y replica en Vercel (producción).
# La app arranca sin ninguna (catálogo local + memoria), pero para
# persistir datos y usar todas las funciones necesitas al menos DATABASE_URL.
# ─────────────────────────────────────────────────────────────

# ── OBLIGATORIAS EN PRODUCCIÓN ───────────────────────────────

# URL pública del sitio (metadatos SEO, sitemap, enlaces absolutos, emails).
# En Vercel: pon el dominio final de la NUEVA cuenta.
NEXT_PUBLIC_APP_URL="https://tu-dominio.com"

# Base de datos PostgreSQL (Aiven). Cópiala de Aiven → Service → Connection
# information → "Service URI". Debe llevar ?sslmode=require al final.
DATABASE_URL="postgres://avnadmin:PASSWORD@HOST-xxx.aivencloud.com:PORT/defaultdb?sslmode=require"

# (Opcional pero recomendado) Certificado CA de Aiven en formato PEM, en UNA
# línea con \n como separadores, para verificar el certificado del servidor.
# Descárgalo de Aiven → "CA Certificate". Si NO la pones, la conexión sigue
# siendo cifrada (TLS) pero sin verificar el certificado.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----\n"

# ── ADMINISTRACIÓN Y CRONS ───────────────────────────────────

# Panel /admin. Sin ella se usa "pescaplus-admin" (solo dev). DEFÍNELA en prod.
ADMIN_PASSWORD="cambia-esta-contrasena"

# Firma de sesión del admin. Genera una larga y aleatoria (ver README abajo).
ADMIN_SESSION_SECRET="un-secreto-largo-aleatorio"

# Secreto para los crons (/api/cron/*). Vercel lo envía como Bearer.
CRON_SECRET="un-secreto-largo-aleatorio"

# ── APIS DE DATOS (previsión / mareas / IA) ──────────────────

# AEMET OpenData (parte marítimo oficial y observaciones de estaciones).
# Es un JWT largo (empieza por "eyJ...").
AEMET_API_KEY="tu_jwt_de_aemet"

# WorldTides (mareas reales).
WORLDTIDES_API_KEY="tu_worldtides_key"

# NVIDIA (asistente IA y generación de textos). La clave empieza por "nvapi".
NVIDIA_API_KEY="tu_clave_de_nvidia"
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
# Cadena de modelos con fallback (si uno falla, prueba el siguiente).
NVIDIA_MODELS="nvidia/nemotron-3-super-120b-a12b,nvidia/llama-3.3-nemotron-super-49b-v1.5,nvidia/nemotron-3-nano-30b-a3b,nvidia/nvidia-nemotron-nano-9b-v2,nvidia/nemotron-mini-4b-instruct"

# ── IMPORTADOR DE PRODUCTOS (AliExpress) ─────────────────────

ALIEXPRESS_APP_KEY="tu_app_key"
ALIEXPRESS_APP_SECRET="tu_app_secret"
ALIEXPRESS_APP_TOKEN="tu_app_token"
ALIEXPRESS_TRACKING_ID="pescaplus"

# ── EMAIL DE ALERTAS (opcional) ──────────────────────────────
# Sin estas, las alertas por email quedan en modo simulación (dry-run).
# RESEND_API_KEY="re_..."
# RESEND_FROM="PescaPlus <alertas@tu-dominio.com>"
