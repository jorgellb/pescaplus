generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  sku          String  @unique @map("aliexpressId")
  title       String
  description String
  imageUrl    String
  images      String[] @default([])
  imageAlts   String[] @default([])
  videoUrl    String   @default("")
  price       Float
  currency    String   @default("EUR")
  affiliateUrl String
  category    String
  typeFishing String   // primary category (spinning, flyfishing, carp, etc.)
  categories  String[] @default([]) // all main categories (includes typeFishing)
  subcategory String   @default("") // primary subcategory (= subcategories[0])
  subcategories String[] @default([]) // all subcategory placements
  rating      Float    @default(0)
  reviews     Int      @default(0)
  inStock     Boolean  @default(true)
  seoTitle    String   @default("")
  seoDescription String @default("")
  aiOptimized Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([typeFishing])
  @@index([category])
}

model FishingAdvice {
  id          String   @id @default(cuid())
  typeFishing String
  title       String
  content     String
  tags        String[]
  relatedProducts String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([typeFishing])
}

model Guide {
  id             String   @id
  title          String
  excerpt        String   @default("")
  content        String
  coverImage     String   @default("")
  coverImageAlt  String   @default("")
  typeFishing    String   @default("")
  seoTitle       String   @default("")
  seoDescription String   @default("")
  aiOptimized    Boolean  @default(false)
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published])
}

model Setting {
  key       String   @id
  value     String   // JSON blob (e.g. taxonomy overrides)
  updatedAt DateTime @updatedAt
}
model ProductClick {
  id           String   @id @default(cuid())
  productId    String
  productTitle String   @default("")
  typeFishing  String   @default("")
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @default("")
  email     String   @default("")
  subject   String   @default("")
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AlertSubscription {
  id        String   @id @default(cuid())
  email     String
  spotSlug  String
  especie   String   @default("")
  threshold Int      @default(75)
  createdAt DateTime @default(now())

  @@unique([email, spotSlug])
  @@index([spotSlug])
}

model ForecastCheck {
  id          String    @id @default(cuid())
  spotSlug    String
  dateISO     String
  targetUtc   String
  idema       String
  predWindKmh Float
  obsWindKmh  Float?
  errorKmh    Float?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@unique([spotSlug, dateISO])
  @@index([spotSlug, resolvedAt])
}
