generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  sku          String  @unique @map("aliexpressId")
  title       String
  description String
  imageUrl    String
  images      String[] @default([])
  imageAlts   String[] @default([])
  videoUrl    String   @default("")
  price       Float
  currency    String   @default("EUR")
  affiliateUrl String
  category    String
  typeFishing String   // primary category (spinning, flyfishing, carp, etc.)
  categories  String[] @default([]) // all main categories (includes typeFishing)
  subcategory String   @default("") // primary subcategory (= subcategories[0])
  subcategories String[] @default([]) // all subcategory placements
  rating      Float    @default(0)
  reviews     Int      @default(0)
  inStock     Boolean  @default(true)
  seoTitle    String   @default("")
  seoDescription String @default("")
  aiOptimized Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([typeFishing])
  @@index([category])
}

model FishingAdvice {
  id          String   @id @default(cuid())
  typeFishing String
  title       String
  content     String
  tags        String[]
  relatedProducts String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([typeFishing])
}

model Guide {
  id             String   @id
  title          String
  excerpt        String   @default("")
  content        String
  coverImage     String   @default("")
  coverImageAlt  String   @default("")
  typeFishing    String   @default("")
  seoTitle       String   @default("")
  seoDescription String   @default("")
  aiOptimized    Boolean  @default(false)
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published])
}

model Setting {
  key       String   @id
  value     String   // JSON blob (e.g. taxonomy overrides)
  updatedAt DateTime @updatedAt
}
model ProductClick {
  id           String   @id @default(cuid())
  productId    String
  productTitle String   @default("")
  typeFishing  String   @default("")
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String   @default("")
  email     String   @default("")
  subject   String   @default("")
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AlertSubscription {
  id        String   @id @default(cuid())
  email     String
  spotSlug  String
  especie   String   @default("")
  threshold Int      @default(75)
  createdAt DateTime @default(now())

  @@unique([email, spotSlug])
  @@index([spotSlug])
}

model ForecastCheck {
  id          String    @id @default(cuid())
  spotSlug    String
  dateISO     String
  targetUtc   String
  idema       String
  predWindKmh Float
  obsWindKmh  Float?
  errorKmh    Float?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  @@unique([spotSlug, dateISO])
  @@index([spotSlug, resolvedAt])
}

model Meetup {
  id           String   @id @default(cuid())
  // Secret token: whoever holds it can edit/cancel the meetup (no accounts).
  manageToken  String   @unique
  hostName     String
  // Contact channel (WhatsApp/phone/email) shown to attendees once they join.
  hostContact  String
  spotSlug     String
  meetingPoint String   @default("")
  dateISO      String // YYYY-MM-DD (local)
  timeStart    String // "07:00" (quedada) o franja ("Mañana") en una llamada
  kind         String   @default("quedada") // quedada | llamada (¿quién se apunta?)
  durationH    Float?
  modality     String // tierra | kayak | barco
  targetSpecies String  @default("")
  level        String   @default("cualquiera") // principiante | medio | experto | cualquiera
  maxPlaces    Int      @default(4)
  minToConfirm Int      @default(1)
  costMode     String   @default("gratis") // gratis | fijo | reparto
  costShare    Float? // per-person fixed cost (costMode 'fijo')
  totalCost    Float? // total to split among all aboard (costMode 'reparto')
  notes        String   @default("")
  status       String   @default("open") // open | confirmed | cancelled
  createdAt    DateTime @default(now())
  rsvps        Rsvp[]

  @@index([spotSlug, dateISO])
  @@index([dateISO])
}

model Rsvp {
  id        String   @id @default(cuid())
  meetupId  String
  name      String
  contact   String   @default("")
  places    Int      @default(1)
  status    String   @default("in") // in | out
  createdAt DateTime @default(now())
  meetup    Meetup   @relation(fields: [meetupId], references: [id], onDelete: Cascade)

  @@index([meetupId])
}
