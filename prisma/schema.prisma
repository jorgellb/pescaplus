generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  aliexpressId String  @unique
  title       String
  description String
  imageUrl    String
  images      String[] @default([])
  imageAlts   String[] @default([])
  videoUrl    String   @default("")
  price       Float
  currency    String   @default("EUR")
  affiliateUrl String
  category    String
  typeFishing String   // spinning, flyfishing, carp, etc.
  rating      Float    @default(0)
  reviews     Int      @default(0)
  inStock     Boolean  @default(true)
  seoTitle    String   @default("")
  seoDescription String @default("")
  aiOptimized Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([typeFishing])
  @@index([category])
}

model FishingAdvice {
  id          String   @id @default(cuid())
  typeFishing String
  title       String
  content     String
  tags        String[]
  relatedProducts String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([typeFishing])
}

model Guide {
  id             String   @id
  title          String
  excerpt        String   @default("")
  content        String
  coverImage     String   @default("")
  typeFishing    String   @default("")
  seoTitle       String   @default("")
  seoDescription String   @default("")
  aiOptimized    Boolean  @default(false)
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published])
}

model ProductClick {
  id           String   @id @default(cuid())
  productId    String
  productTitle String   @default("")
  typeFishing  String   @default("")
  createdAt    DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
